generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id         String   @id @default(uuid())
  name       String
  address    String?
  createdAt  DateTime @default(now()) @map("created_at")
  users      User[]
  tables     FloorTable[]
  categories Category[]
  products   Product[]
  customers  Customer[]
  orders     Order[]
  reservations Reservation[]
  bottleKeepers BottleKeeper[]
  promotions Promotion[]
  inventoryTransactions InventoryTransaction[]
  schedules  Schedule[]
  rolePermissions RolePermission[]
  @@map("branches")
}

model User {
  id           String   @id @default(uuid())
  branchId     String?  @map("branch_id")
  branch       Branch?  @relation(fields: [branchId], references: [id])
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("cashier")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  orders       Order[]
  auditLogs    AuditLog[]
  inventoryTransactions InventoryTransaction[]
  schedules    Schedule[]
  @@map("users")
}

model FloorTable {
  id        String   @id @default(uuid())
  branchId  String?  @map("branch_id")
  branch    Branch?  @relation(fields: [branchId], references: [id])
  name      String
  capacity  Int      @default(4)
  posX      Float    @default(0) @map("pos_x")
  posY      Float    @default(0) @map("pos_y")
  status    String   @default("available")
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]
  reservations Reservation[]
  @@map("floor_tables")
}

model Category {
  id       String    @id @default(uuid())
  branchId String?   @map("branch_id")
  branch   Branch?   @relation(fields: [branchId], references: [id])
  name     String
  type     String    @default("food")
  products Product[]
  @@map("categories")
}

model Product {
  id         String   @id @default(uuid())
  branchId   String?  @map("branch_id")
  branch     Branch?  @relation(fields: [branchId], references: [id])
  categoryId String?  @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])
  name       String
  price      Decimal  @db.Decimal(10, 2)
  cost       Decimal  @default(0) @db.Decimal(10, 2)
  stock      Int      @default(0)
  unit       String   @default("pcs")
  imageUrl   String?  @map("image_url")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  orderItems OrderItem[]
  bottleKeepers BottleKeeper[]
  inventoryTransactions InventoryTransaction[]
  @@map("products")
}

model Customer {
  id        String   @id @default(uuid())
  branchId  String?  @map("branch_id")
  branch    Branch?  @relation(fields: [branchId], references: [id])
  name      String
  phone     String?
  email     String?
  points    Int      @default(0)
  tier      String   @default("normal")
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]
  reservations Reservation[]
  bottleKeepers BottleKeeper[]
  @@map("customers")
}

model Reservation {
  id         String   @id @default(uuid())
  branchId   String?  @map("branch_id")
  branch     Branch?  @relation(fields: [branchId], references: [id])
  tableId    String?  @map("table_id")
  table      FloorTable? @relation(fields: [tableId], references: [id])
  customerId String?  @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])
  reservedAt DateTime @map("reserved_at")
  guests     Int      @default(1)
  note       String?
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")
  @@map("reservations")
}

model Order {
  id            String   @id @default(uuid())
  branchId      String?  @map("branch_id")
  branch        Branch?  @relation(fields: [branchId], references: [id])
  tableId       String?  @map("table_id")
  table         FloorTable? @relation(fields: [tableId], references: [id])
  customerId    String?  @map("customer_id")
  customer      Customer? @relation(fields: [customerId], references: [id])
  staffId       String?  @map("staff_id")
  staff         User?    @relation(fields: [staffId], references: [id])
  status        String   @default("open")
  subtotal      Decimal  @default(0) @db.Decimal(10, 2)
  discount      Decimal  @default(0) @db.Decimal(10, 2)
  serviceCharge Decimal  @default(0) @db.Decimal(10, 2) @map("service_charge")
  vat           Decimal  @default(0) @db.Decimal(10, 2)
  total         Decimal  @default(0) @db.Decimal(10, 2)
  paymentMethod String?  @map("payment_method")
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")
  paidAt        DateTime? @map("paid_at")
  items         OrderItem[]
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?  @map("product_id")
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  price     Decimal  @db.Decimal(10, 2)
  qty       Int      @default(1)
  note      String?
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("order_items")
}

model BottleKeeper {
  id          String   @id @default(uuid())
  branchId    String?  @map("branch_id")
  branch      Branch?  @relation(fields: [branchId], references: [id])
  customerId  String?  @map("customer_id")
  customer    Customer? @relation(fields: [customerId], references: [id])
  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])
  bottleLabel String?  @map("bottle_label")
  remaining   Decimal  @default(0) @db.Decimal(6, 2)
  openedAt    DateTime @default(now()) @map("opened_at")
  expiresAt   DateTime? @map("expires_at")
  note        String?
  @@map("bottle_keepers")
}

model Promotion {
  id        String   @id @default(uuid())
  branchId  String?  @map("branch_id")
  branch    Branch?  @relation(fields: [branchId], references: [id])
  name      String
  type      String
  value     Decimal  @default(0) @db.Decimal(10, 2)
  minAmount Decimal  @default(0) @db.Decimal(10, 2) @map("min_amount")
  startsAt  DateTime? @map("starts_at")
  endsAt    DateTime? @map("ends_at")
  isActive  Boolean  @default(true) @map("is_active")
  @@map("promotions")
}

model InventoryTransaction {
  id        String   @id @default(uuid())
  branchId  String?  @map("branch_id")
  branch    Branch?  @relation(fields: [branchId], references: [id])
  productId String?  @map("product_id")
  product   Product? @relation(fields: [productId], references: [id])
  type      String
  qty       Int
  note      String?
  createdBy String?  @map("created_by")
  creator   User?    @relation(fields: [createdBy], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  @@map("inventory_transactions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  detail    Json?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("audit_logs")
}

model RolePermission {
  id       String  @id @default(uuid())
  branchId String? @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id])
  role     String
  action   String
  allowed  Boolean @default(true)
  @@unique([branchId, role, action])
  @@map("role_permissions")
}

model Schedule {
  id        String   @id @default(uuid())
  branchId  String?  @map("branch_id")
  branch    Branch?  @relation(fields: [branchId], references: [id])
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @db.Date
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("schedules")
}
